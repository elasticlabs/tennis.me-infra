logging {
  level = "info"
}

loki.write "default" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}

loki.source.file "nginx_logs" {
  targets = [
    { __path__ = "/var/log/nginx/*.log" }
  ]
}

loki.process "nginx" {
  forward_to = [loki.write.default.receiver]
}

loki.source.file.nginx_logs -> loki.process.nginx