    {
      "type": "logs",
      "title": "Auth Logs",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "{job=\"docker-json\", service=~\"keycloak|oauth2-proxy\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Keycloak Auth Errors",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"docker-json\", service=\"keycloak\"} |~ \"(?i)error|failed|invalid\"[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "oauth2-proxy Errors",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"docker-json\", service=\"oauth2-proxy\"} |~ \"(?i)error|denied|forbidden|unauthorized\"[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Fail2ban Ban Events",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"docker-json\", service=\"fail2ban\"} |= \"Ban \"[5m]))",
          "refId": "A"
        }
      ]
    }
