COMPOSE_PROJECT_NAME=tennisme-revproxy

TZ=Europe/Paris
PUID=1000
PGID=1000

BASE_DOMAIN=elasticlabs.co
ADMIN_EMAIL=admin@elasticlabs.co

REVPROXY_APPS_NETWORK=revproxy_apps
SWAG_NETWORK=swag_net

SWAG_URL=${BASE_DOMAIN}
SWAG_SUBDOMAINS=auth,admin,labs
SWAG_VALIDATION=http
SWAG_ONLY_SUBDOMAINS=true
SWAG_STAGING=false

KEYCLOAK_VERSION=26.5.7
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=CHANGE_ME
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_HOSTNAME=https://auth.${BASE_DOMAIN}

OAUTH2_PROXY_CLIENT_ID=admin-gateway
OAUTH2_PROXY_CLIENT_SECRET=CHANGE_ME
OAUTH2_PROXY_COOKIE_SECRET=CHANGE_ME

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME