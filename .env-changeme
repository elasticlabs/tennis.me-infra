# --- project ---
COMPOSE_PROJECT_NAME=tennisme-revproxy

# --- system ---
TZ=Europe/Paris
PUID=1000
PGID=1000

# --- domain ---
BASE_DOMAIN=elasticlabs.co
ADMIN_EMAIL=admin@elasticlabs.co

# --- networks ---
REVPROXY_APPS_NETWORK=revproxy_apps
SWAG_NETWORK=swag_net

# --- swag / nginx ---
SWAG_URL=${BASE_DOMAIN}
SWAG_SUBDOMAINS=auth,admin,labs
SWAG_VALIDATION=http
SWAG_ONLY_SUBDOMAINS=true
SWAG_STAGING=false

# --- keycloak ---
KEYCLOAK_VERSION=26.5.7
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=CHANGE_ME_DB_PASSWORD
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
KEYCLOAK_HOSTNAME=https://auth.${BASE_DOMAIN}

# --- oauth2-proxy (SSO gateway) ---
OAUTH2_PROXY_CLIENT_ID=admin-gateway
OAUTH2_PROXY_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET
OAUTH2_PROXY_COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET

# --- grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD